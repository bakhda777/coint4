[Unit]
Description=Autonomous Strict Fullspan Contract Auditor
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=__ROOT_DIR__
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/env python3 __ROOT_DIR__/scripts/optimization/contract_auditor_agent.py

[Install]
WantedBy=default.target
