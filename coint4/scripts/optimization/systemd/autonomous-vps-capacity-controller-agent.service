[Unit]
Description=Autonomous VPS Capacity Controller Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=__ROOT_DIR__
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/env python3 __ROOT_DIR__/scripts/optimization/vps_capacity_controller_agent.py

[Install]
WantedBy=default.target
