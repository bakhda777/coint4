[Unit]
Description=Autonomous Single Writer Guard Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=__ROOT_DIR__
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/env python3 __ROOT_DIR__/scripts/optimization/single_writer_guard_agent.py

[Install]
WantedBy=default.target
