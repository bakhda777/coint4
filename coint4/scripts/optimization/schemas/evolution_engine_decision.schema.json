{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "coint4 evolution engine decision (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "engine_id",
    "created_at",
    "generation",
    "seed",
    "rng",
    "controller_group",
    "run_group",
    "queue_path",
    "base_config_path",
    "knob_space",
    "reward",
    "similarity",
    "operators",
    "proposals"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["v1"] },
    "decision_id": { "type": "string" },
    "engine_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "generation": { "type": "integer", "minimum": 0 },
    "seed": { "type": "integer" },
    "rng": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "state"],
      "properties": {
        "algorithm": { "type": "string", "enum": ["PCG64"] },
        "state": { "type": "object" },
        "notes": { "type": "string" }
      }
    },
    "controller_group": { "type": "string" },
    "run_group": { "type": "string" },
    "queue_path": { "type": "string" },
    "base_config_path": { "type": "string" },
    "knob_space": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "type"],
        "properties": {
          "key": { "$ref": "#/definitions/dotted_key" },
          "type": {
            "type": "string",
            "enum": ["int", "float", "bool", "categorical", "string"]
          },
          "min": { "type": ["number", "null"] },
          "max": { "type": ["number", "null"] },
          "step": { "type": ["number", "null"] },
          "choices": {
            "type": ["array", "null"],
            "items": { "$ref": "#/definitions/genome_value" }
          },
          "round_to": { "type": ["integer", "null"], "minimum": 0 },
          "weight": { "type": ["number", "null"], "minimum": 0.0 },
          "norm": {
            "type": ["string", "null"],
            "enum": ["range", "step", "none", null]
          }
        }
      }
    },
    "reward": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "hard_gates"],
      "properties": {
        "profile": { "type": "string", "enum": ["short_oos_v1", "fullspan_v1"] },
        "hard_gates": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "require_metrics",
            "min_windows",
            "min_trades",
            "min_pairs",
            "max_dd_pct",
            "min_pnl"
          ],
          "properties": {
            "require_metrics": { "type": "boolean" },
            "min_windows": { "type": "integer", "minimum": 1 },
            "min_trades": { "type": "integer", "minimum": 0 },
            "min_pairs": { "type": "integer", "minimum": 0 },
            "max_dd_pct": { "type": "number", "minimum": 0.0 },
            "min_pnl": { "type": "number" }
          }
        },
        "dd_penalty": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["target_pct", "k"],
          "properties": {
            "target_pct": { "type": "number", "minimum": 0.0 },
            "k": { "type": "number", "minimum": 0.0 }
          }
        },
        "fullspan_policy_v1": { "type": ["object", "null"] }
      }
    },
    "similarity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "dedupe_threshold", "normalization"],
      "properties": {
        "metric": { "type": "string", "enum": ["genome_weighted_l1_v1"] },
        "dedupe_threshold": { "type": "number", "minimum": 0.0 },
        "normalization": { "type": "string", "enum": ["range", "step", "none"] },
        "key_weights": {
          "type": ["object", "null"],
          "propertyNames": { "$ref": "#/definitions/dotted_key" },
          "additionalProperties": { "type": "number", "minimum": 0.0 }
        }
      }
    },
    "operators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["operator_id", "kind", "budget", "params"],
        "properties": {
          "operator_id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": [
              "mutate_step_v1",
              "crossover_uniform_v1",
              "random_restart_v1",
              "coordinate_sweep_v1"
            ]
          },
          "budget": { "type": "integer", "minimum": 0 },
          "params": { "type": "object" }
        }
      }
    },
    "proposals": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/proposal" }
    },
    "outputs": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "state_path": { "type": "string" },
        "decision_path": { "type": "string" },
        "created_files": { "type": "array", "items": { "type": "string" } }
      }
    },
    "notes_md": { "type": ["string", "null"] }
  },
  "definitions": {
    "dotted_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_]+(\\.[A-Za-z0-9_]+)*$"
    },
    "genome_value": {
      "type": ["number", "integer", "string", "boolean", "null"]
    },
    "genome": {
      "type": "object",
      "propertyNames": { "$ref": "#/definitions/dotted_key" },
      "additionalProperties": { "$ref": "#/definitions/genome_value" }
    },
    "materialization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config_path", "results_dir", "status"],
      "properties": {
        "config_path": { "type": "string" },
        "results_dir": { "type": "string" },
        "status": { "type": "string", "enum": ["planned"] }
      }
    },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "operator_id", "parents", "genome", "materialization"],
      "properties": {
        "candidate_id": { "type": "string" },
        "operator_id": { "type": "string" },
        "parents": { "type": "array", "items": { "type": "string" } },
        "genome": { "$ref": "#/definitions/genome" },
        "materialization": { "$ref": "#/definitions/materialization" },
        "notes": { "type": ["string", "null"] },
        "similarity": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "nearest_id": { "type": "string" },
            "distance": { "type": "number", "minimum": 0.0 }
          }
        }
      }
    }
  }
}

